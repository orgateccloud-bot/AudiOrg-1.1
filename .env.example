# ================================================================================
# OrgAudi — Template de variáveis de ambiente
# ================================================================================
# Copie este arquivo para `config.env` e preencha os valores reais.
# NUNCA commite arquivos com valores reais — `config.env` e `.env` estão no .gitignore.
# ================================================================================

# ─── PROVEDOR DE IA (Anthropic) ───────────────────────────────────────────────
AI_PROVEDOR=anthropic
SQUAD_MODEL=anthropic:claude-sonnet-4-6
AUDITORIA_MODEL=anthropic:claude-sonnet-4-6
AUDITORIA_MODEL_SIMPLES=anthropic:claude-haiku-4-5-20251001

# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Produção: Supabase Postgres (Transaction Pooler — porta 6543, compatível pgBouncer)
# Obtenha em: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.SUPABASE_PROJECT_REF:SUPABASE_DB_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# Direct connection (porta 5432) — necessário APENAS para: alembic upgrade head
# Não usar em runtime — o Transaction Pooler acima é o correto para a aplicação
DATABASE_URL_DIRECT=postgresql://postgres:SUPABASE_DB_PASSWORD@db.SUPABASE_PROJECT_REF.supabase.co:5432/postgres

# Desenvolvimento local (sem DATABASE_URL) → SQLite orgatec_sovereign.db (auto-criado)
# Não é necessário nenhum setup adicional para rodar em dev.

# ─── AMBIENTE ─────────────────────────────────────────────────────────────────
# production → exige PostgreSQL (RuntimeError se DATABASE_URL ausente ou inválida)
# development → SQLite como fallback se DATABASE_URL vazio
ENV=production

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Usado apenas como backend Postgres (DATABASE_URL acima).
# Chaves de SDK não são necessárias — módulo Finance removido.
SUPABASE_URL=https://SUPABASE_PROJECT_REF.supabase.co

# ─── JWT (Autenticação API) ──────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=GERAR_COM_SECRETS_TOKEN_URLSAFE_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── REPORT ───────────────────────────────────────────────────────────────────
REPORT_LANG=pt_BR
REPORT_THEME=dark_mode
CHART_DPI=300

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=extractor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ─── APPLICATION ──────────────────────────────────────────────────────────────
DEBUG=False
APP_NAME=OrgAudi NFA Extractor
APP_VERSION=2.0.0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula. Vazio → defaults de dev (localhost:5173-5175).
# Produção exemplo: ALLOWED_ORIGINS=https://audi.orgatec.com.br,https://app.orgatec.com.br
ALLOWED_ORIGINS=

# ─── UPLOAD DE PDF (auditoria) ────────────────────────────────────────────────
# Limites do endpoint POST /auditoria/upload/{client_id}.
# Defaults: 10 MB por arquivo, 50 MB por lote, 20 arquivos por lote.
UPLOAD_MAX_BYTES=10485760
UPLOAD_LOTE_MAX_BYTES=52428800
UPLOAD_MAX_FILES=20

# ─── LGPD / Protocolo @Delta ──────────────────────────────────────────────────
# Caminho de arquivo append-only para log de anonimização/des-anonimização.
# Se vazio, o log vai junto do structlog padrão (stdout).
LGPD_DELTA_LOG=

# ─── JWT — extensão ──────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Bootstrap admin (seed inicial) ──────────────────────────────────────────
# Header X-Seed-Token igual a este valor é exigido para POST /auth/seed
SEED_BOOTSTRAP_TOKEN=
ADMIN_EMAIL=admin@orgatec.com.br
# Mínimo 12 caracteres
ADMIN_INITIAL_PASSWORD=
