# ================================================================================
# OrgAudi — Template de variáveis de ambiente
# ================================================================================
# Copie este arquivo para `.env` (ou `config.env`) e preencha os valores reais.
# NUNCA commite arquivos com valores reais — `.env` e `config.env` estão no .gitignore.
# ================================================================================

# ─── PROVEDOR DE IA (Anthropic) ───────────────────────────────────────────────
AI_PROVEDOR=anthropic
SQUAD_MODEL=anthropic:claude-sonnet-4-6
AUDITORIA_MODEL=anthropic:claude-sonnet-4-6
AUDITORIA_MODEL_SIMPLES=anthropic:claude-haiku-4-5-20251001

# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-SUBSTITUA_PELA_SUA_CHAVE_REAL

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Postgres local (Docker Compose) — usar para desenvolvimento
DATABASE_URL=postgresql://nfa_user:CHANGE_ME@localhost:5433/nfa_extractor

# Postgres docker-compose (mantenha em sincronia com DATABASE_URL)
POSTGRES_USER=nfa_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nfa_extractor

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Console: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── JWT (Autenticação API) ──────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=GERAR_COM_SECRETS_TOKEN_URLSAFE_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── REPORT ───────────────────────────────────────────────────────────────────
REPORT_LANG=pt_BR
REPORT_THEME=dark_mode
CHART_DPI=300

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=extractor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ─── APPLICATION ──────────────────────────────────────────────────────────────
DEBUG=False
APP_NAME=OrgAudi NFA Extractor
APP_VERSION=2.0.0

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Senha do usuário admin criado no primeiro boot
ADMIN_INITIAL_PASSWORD=GERAR_SENHA_FORTE_AQUI

# ─── NFA-REPO (Extrator de PDFs SEFAZ-GO) ────────────────────────────────────
# Path local do repositório nfa-repo (usado por nfa_bridge)
NFA_REPO_PATH=D:\nfa-repo

# ─── ML — Modelos Opcionais ───────────────────────────────────────────────────
# Path do modelo XGBoost treinado (.json). Vazio = modo heurístico (padrão).
XGBOOST_MODEL_PATH=

# Path do modelo LSTM treinado (.pt). Vazio = modo heurístico (padrão).
LSTM_MODEL_PATH=

# ─── MCP (Model Context Protocol) ────────────────────────────────────────────
# Domínios extras autorizados para buscar_dados_externos (além dos padrão gov.br)
MCP_FETCH_ALLOWLIST=

# Override do caminho do banco SQLite (padrão: orgatec_sovereign.db na raiz)
ORGAUDI_DB_PATH=
